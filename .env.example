# Server
PORT=3000
NODE_ENV=development

# PostgreSQL (local dev — Render sets DATABASE_URL automatically)
DATABASE_URL=postgresql://postgres:password@localhost:5432/champro

# Google Sheets
GOOGLE_SHEET_ID=1rFmuB_25AmVBsVpsKWV5FB7v452TSWrkF9k3e_EMyNM
GOOGLE_SHEET_TAB=SAMPLES
# Paste your service account JSON here (minified, single line)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# CPA Credentials
CPA_USER=rgarcia1
CPA_PASS=XkK9Zn^KI9*6@H
CPA_BASE_URL=https://cp.champrosports.com

# Scraper schedule (cron syntax)
# Every 2 hours: "0 */2 * * *"
# Every 30 min:  "*/30 * * * *"
SCRAPER_SCHEDULE=0 */2 * * *

# Sync schedule (every 10 minutes)
SYNC_SCHEDULE=*/10 * * * *
